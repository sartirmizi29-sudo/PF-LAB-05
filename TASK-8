#include <stdio.h>

int main() {
int choice;
float weight, height, age, result;

printf("=== Advanced Health Calculator ===\n");
printf("1. BMI Calculation\n");
printf("2. BMR Calculation\n");
printf("3. Ideal Weight (Devine Formula)\n");
printf("4. Heart Rate Zone\n");
printf("Enter your choice: ");
scanf("%d", &choice);

switch (choice) {

case 1:  // BMI
printf("Enter weight (kg): ");
scanf("%f", &weight);
printf("Enter height (meters): ");
scanf("%f", &height);

if (weight > 0 && height > 0) {
result = weight / pow(height, 2);
printf("Your BMI is: %.2f\n", result);
} else {
printf("Error: Weight and height must be positive!\n");
}
break;

case 2:  // BMR (Mifflin-St Jeor simplified for male)
printf("Enter weight (kg): ");
scanf("%f", &weight);
printf("Enter height (cm): ");
scanf("%f", &height);
printf("Enter age (years): ");
scanf("%f", &age);


if (weight > 0 && height > 0) {
if (age > 0) {
result = 10 * weight + 6.25 * height - 5 * age + 5;
printf("Your BMR is: %.2f calories/day\n", result);
} else {
printf("Error: Age must be positive!\n");
}
} else {
printf("Error: Weight and height must be positive!\n");
}
break;

case 3:  // Ideal Weight (Devine Formula for male)
printf("Enter height (in inches): ");
scanf("%f", &height);

if (height > 0) {
result = 50 + 2.3 * fabs(height - 60);
printf("Your Ideal Weight is: %.2f kg\n", result);
} else {
printf("Error: Height must be positive!\n");
}
break;

case 4:  // Heart Rate Zone
printf("Enter age (years): ");
scanf("%f", &age);

if (age > 0) {
float maxHR = 220 - age;
float lowerZone = 0.5 * maxHR;
float upperZone = 0.85 * maxHR;
printf("Max Heart Rate: %.2f bpm\n", maxHR);
printf("Target Heart Rate Zone: %.2f - %.2f bpm\n", lowerZone, upperZone);

// Using sqrt just to demonstrate math library usage
printf("Square root of Max HR (demo): %.2f\n", sqrt(maxHR));
} else {
printf("Error: Age must be positive!\n");
}
break;

default:
printf("Invalid choice!\n");
}
return 0;
}
