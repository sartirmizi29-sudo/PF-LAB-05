#include <stdio.h>

int main() {
    float salary, incentive;
    int serviceYears;

    // Input
    printf("Enter Salary: ");
    scanf("%f", &salary);
    printf("Enter Years of Service: ");
    scanf("%d", &serviceYears);

    // Nested ternary operator
    incentive = (serviceYears > 15) ? (0.35 * salary) :
                (serviceYears > 7)  ? (0.20 * salary) :
                                       (0.05 * salary);
    // Output
    printf("Incentive Amount: Rs. %.2f\n", incentive);

    return 0;
}
